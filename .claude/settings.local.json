{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(wc:*)",
      "WebFetch(domain:unstract.com)",
      "WebFetch(domain:blog.roboflow.com)",
      "WebFetch(domain:pyimagesearch.com)",
      "WebFetch(domain:developers.deepl.com)",
      "WebFetch(domain:ai.google.dev)",
      "WebFetch(domain:docs.x.ai)",
      "WebFetch(domain:realpython.com)",
      "WebFetch(domain:www.langchain.com)",
      "WebFetch(domain:crewai.com)",
      "WebFetch(domain:github.com)",
      "Bash(python3:*)",
      "Bash(python:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/lint.sh",
            "description": "파일 수정 후 자동 린트 실행"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Hook] Bash 명령 실행 전 확인 중...'",
            "description": "Bash 실행 전 로그"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f TODO.md ]; then echo '[세션 종료] TODO.md 업데이트를 잊지 마세요!'; fi",
            "description": "세션 종료 시 TODO 업데이트 리마인더"
          }
        ]
      }
    ]
  }
}
